			"name": "Zdeněk Papučík",
			"homepage": "https://github.com/accgit"
		}
	],
	"require": {
		"php": ">=8.3 <9",
		"nette/application": "^3.1",
		"nette/http": "^3.1",
		"nette/di": "^3.0",
		"nette/security": "^3.2",
		"stevenmaguire/oauth2-keycloak": "^6.1"
	},
	"require-dev": {
		"nette/tester": "^2.3",
